{
  "name": "TT2GO - Standorte täglich nach GitHub",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 6 * * *" }
          ]
        }
      },
      "id": "cron-trigger",
      "name": "Täglich um 6 Uhr",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://my.fleetster.net/users/auth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ email: $env.FLEETSTER_EMAIL, password: $env.FLEETSTER_PASSWORD }) }}",
        "options": {}
      },
      "id": "auth-login",
      "name": "Fleetster Login",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 400]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nreturn [{ json: { token: response._id } }];"
      },
      "id": "extract-token",
      "name": "Token extrahieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 400]
    },
    {
      "parameters": {
        "url": "https://my.fleetster.net/locations?deleted=false",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ $json.token }}" }
          ]
        },
        "options": {}
      },
      "id": "get-locations",
      "name": "Standorte abrufen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 400]
    },
    {
      "parameters": {
        "jsCode": "const locItems = $('Standorte abrufen').all().map(i => i.json);\n\nlet locations = locItems;\nif (locItems.length === 1 && Array.isArray(locItems[0])) locations = locItems[0];\n\nconst stations = locations\n  .filter(loc => loc.extended && loc.extended.GeoPosition && loc.extended.GeoPosition.latitude)\n  .map(loc => ({\n    id: loc._id,\n    name: loc.name || '',\n    city: loc.city || '',\n    postcode: loc.postcode || '',\n    street: ((loc.streetName || '') + ' ' + (loc.streetNumber || '')).trim(),\n    lat: loc.extended.GeoPosition.latitude,\n    lng: loc.extended.GeoPosition.longitude,\n    comment: loc.comment || ''\n  }))\n  .sort((a, b) => a.name.localeCompare(b.name));\n\nconst result = {\n  stations: stations,\n  updated: new Date().toISOString()\n};\n\n// GitHub Token für die nächsten Nodes mitgeben\nconst githubToken = $env.GITHUB_TOKEN || '';\n\nreturn [{ json: { content: JSON.stringify(result, null, 2), githubToken: githubToken } }];"
      },
      "id": "format-response",
      "name": "JSON formatieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 400]
    },
    {
      "parameters": {
        "url": "https://api.github.com/repos/andreastheurer-tt2go/theurer-trucks-2go-webseite/contents/api/data.json",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json.githubToken }}" },
            { "name": "Accept", "value": "application/vnd.github.v3+json" },
            { "name": "User-Agent", "value": "n8n-tt2go" }
          ]
        },
        "options": {
          "response": { "response": { "neverError": true } }
        }
      },
      "id": "github-get-sha",
      "name": "Bestehende Datei SHA holen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 400]
    },
    {
      "parameters": {
        "jsCode": "const fileCheck = $input.first().json;\nconst content = $('JSON formatieren').first().json.content;\nconst githubToken = $('JSON formatieren').first().json.githubToken;\nconst sha = fileCheck.sha || null;\n\nconst contentBase64 = Buffer.from(content, 'utf-8').toString('base64');\n\nconst body = {\n  message: 'chore: Standorte aktualisiert (' + new Date().toISOString().slice(0,10) + ')',\n  content: contentBase64\n};\n\nif (sha) body.sha = sha;\n\nreturn [{ json: { body: body, githubToken: githubToken } }];"
      },
      "id": "prepare-push",
      "name": "Push vorbereiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 400]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "https://api.github.com/repos/andreastheurer-tt2go/theurer-trucks-2go-webseite/contents/api/data.json",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json.githubToken }}" },
            { "name": "Accept", "value": "application/vnd.github.v3+json" },
            { "name": "User-Agent", "value": "n8n-tt2go" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.body) }}",
        "options": { "timeout": 30000 }
      },
      "id": "github-push",
      "name": "Nach GitHub pushen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 400]
    }
  ],
  "connections": {
    "Täglich um 6 Uhr": { "main": [[{ "node": "Fleetster Login", "type": "main", "index": 0 }]] },
    "Fleetster Login": { "main": [[{ "node": "Token extrahieren", "type": "main", "index": 0 }]] },
    "Token extrahieren": { "main": [[{ "node": "Standorte abrufen", "type": "main", "index": 0 }]] },
    "Standorte abrufen": { "main": [[{ "node": "JSON formatieren", "type": "main", "index": 0 }]] },
    "JSON formatieren": { "main": [[{ "node": "Bestehende Datei SHA holen", "type": "main", "index": 0 }]] },
    "Bestehende Datei SHA holen": { "main": [[{ "node": "Push vorbereiten", "type": "main", "index": 0 }]] },
    "Push vorbereiten": { "main": [[{ "node": "Nach GitHub pushen", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
