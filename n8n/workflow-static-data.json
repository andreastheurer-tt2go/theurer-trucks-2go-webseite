{
  "name": "TT2GO - Statische Daten (täglich → GitHub)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 6 * * *" }
          ]
        }
      },
      "id": "cron-trigger",
      "name": "Täglich um 6 Uhr",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://my.fleetster.net/users/auth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ email: $env.FLEETSTER_EMAIL, password: $env.FLEETSTER_PASSWORD }) }}",
        "options": {}
      },
      "id": "auth-login",
      "name": "Fleetster Login",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 400]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nreturn [{ json: { token: response._id } }];"
      },
      "id": "extract-token",
      "name": "Token extrahieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 400]
    },
    {
      "parameters": {
        "url": "https://my.fleetster.net/locations",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ $json.token }}" }
          ]
        },
        "options": {}
      },
      "id": "get-locations",
      "name": "Standorte abrufen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 400]
    },
    {
      "parameters": {
        "url": "https://my.fleetster.net/vehicles",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ $('Token extrahieren').first().json.token }}" }
          ]
        },
        "options": {}
      },
      "id": "get-vehicles",
      "name": "Fahrzeuge abrufen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 400]
    },
    {
      "parameters": {
        "url": "https://my.fleetster.net/users?limit=0",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ $('Token extrahieren').first().json.token }}" }
          ]
        },
        "options": {}
      },
      "id": "get-users",
      "name": "Nutzer abrufen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 400]
    },
    {
      "parameters": {
        "jsCode": "// Daten aus den vorherigen Nodes\nconst locRaw = $('Standorte abrufen').all().map(i => i.json);\nconst vehRaw = $('Fahrzeuge abrufen').all().map(i => i.json);\nconst usrRaw = $('Nutzer abrufen').all().map(i => i.json);\n\nconst locations = locRaw.length === 1 && Array.isArray(locRaw[0]) ? locRaw[0] : locRaw;\nconst vehicles = vehRaw.length === 1 && Array.isArray(vehRaw[0]) ? vehRaw[0] : vehRaw;\nconst users = usrRaw.length === 1 && Array.isArray(usrRaw[0]) ? usrRaw[0] : usrRaw;\n\n// Standorte formatieren\nconst stations = locations\n  .filter(loc => !loc.deleted)\n  .filter(loc => loc.extended && loc.extended.GeoPosition && loc.extended.GeoPosition.latitude)\n  .map(loc => ({\n    id: loc._id,\n    name: loc.name || '',\n    city: loc.city || '',\n    postcode: loc.postcode || '',\n    street: (loc.streetName || '') + ' ' + (loc.streetNumber || ''),\n    lat: loc.extended.GeoPosition.latitude,\n    lng: loc.extended.GeoPosition.longitude,\n    comment: loc.comment || ''\n  }))\n  .sort((a, b) => a.name.localeCompare(b.name));\n\n// Fahrzeuge pro Standort\nconst vehiclesByLocation = {};\nvehicles.forEach(v => {\n  if (v.locationId && !v.deleted) {\n    vehiclesByLocation[v.locationId] = (vehiclesByLocation[v.locationId] || 0) + 1;\n  }\n});\nstations.forEach(s => {\n  s.vehicleCount = vehiclesByLocation[s.id] || 0;\n});\n\nconst result = {\n  stations: stations,\n  stats: {\n    vehicles: vehicles.filter(v => !v.deleted).length,\n    stations: stations.length,\n    users: users.length\n  },\n  updated: new Date().toISOString()\n};\n\nreturn [{ json: { content: JSON.stringify(result, null, 2) } }];"
      },
      "id": "format-response",
      "name": "JSON formatieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 400]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "=https://api.github.com/repos/andreastheurer-tt2go/theurer-trucks-2go-webseite/contents/api/data.json",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.GITHUB_TOKEN }}" },
            { "name": "Accept", "value": "application/vnd.github.v3+json" },
            { "name": "User-Agent", "value": "n8n-tt2go" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ message: 'chore: API-Daten aktualisiert (' + new Date().toISOString().slice(0,10) + ')', content: Buffer.from($json.content).toString('base64'), sha: $json.sha || undefined }) }}",
        "options": { "timeout": 30000 }
      },
      "id": "github-push",
      "name": "GitHub Push",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2000, 400]
    },
    {
      "parameters": {
        "url": "https://api.github.com/repos/andreastheurer-tt2go/theurer-trucks-2go-webseite/contents/api/data.json",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.GITHUB_TOKEN }}" },
            { "name": "Accept", "value": "application/vnd.github.v3+json" },
            { "name": "User-Agent", "value": "n8n-tt2go" }
          ]
        },
        "options": {
          "response": { "response": { "neverError": true } }
        }
      },
      "id": "github-get-sha",
      "name": "Bestehende Datei prüfen (SHA)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 400]
    },
    {
      "parameters": {
        "jsCode": "const fileCheck = $input.first().json;\nconst content = $('JSON formatieren').first().json.content;\n\n// SHA der bestehenden Datei holen (nötig für Update)\nconst sha = fileCheck.sha || null;\n\nreturn [{ json: { content, sha } }];"
      },
      "id": "prepare-push",
      "name": "Push vorbereiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 400]
    }
  ],
  "connections": {
    "Täglich um 6 Uhr": { "main": [[{ "node": "Fleetster Login", "type": "main", "index": 0 }]] },
    "Fleetster Login": { "main": [[{ "node": "Token extrahieren", "type": "main", "index": 0 }]] },
    "Token extrahieren": { "main": [[{ "node": "Standorte abrufen", "type": "main", "index": 0 }]] },
    "Standorte abrufen": { "main": [[{ "node": "Fahrzeuge abrufen", "type": "main", "index": 0 }]] },
    "Fahrzeuge abrufen": { "main": [[{ "node": "Nutzer abrufen", "type": "main", "index": 0 }]] },
    "Nutzer abrufen": { "main": [[{ "node": "JSON formatieren", "type": "main", "index": 0 }]] },
    "JSON formatieren": { "main": [[{ "node": "Bestehende Datei prüfen (SHA)", "type": "main", "index": 0 }]] },
    "Bestehende Datei prüfen (SHA)": { "main": [[{ "node": "Push vorbereiten", "type": "main", "index": 0 }]] },
    "Push vorbereiten": { "main": [[{ "node": "GitHub Push", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
