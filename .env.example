# TheurerTrucks 2GO — API Zugangsdaten (Vorlage)
# Kopiere diese Datei zu .env und trage deine Werte ein.

# Fleetster API
FLEETSTER_API_KEY=dein-api-key-hier
FLEETSTER_API_URL=https://my.fleetster.net/api/v2

# n8n VPS
N8N_BASE_URL=https://n8n.dein-server.de
N8N_WEBHOOK_SECRET=dein-webhook-secret

# VPS
VPS_IP=123.456.789.0

# --- Postgres (VPS, tt2go-postgres Container) ---
# Werden auf dem VPS in der docker-compose .env gesetzt, nicht lokal.
# Hier nur als Referenz.
TT2GO_POSTGRES_DB=tt2go_reports
TT2GO_POSTGRES_USER=tt2go
TT2GO_POSTGRES_PASSWORD=

# --- Slack Bot ---
# Werden in n8n als Environment-Variablen gesetzt, nicht in dieser Datei.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...
SLACK_ALLOWED_USERS=U07XXXXXXX         # comma-separated Slack User-IDs
